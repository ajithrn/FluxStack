{
    "apiVersion": 3,
    "name": "fluxstack/cta",
    "title": "CTA Banner",
    "category": "fluxstack",
    "icon": "megaphone",
    "description": "Call-to-action banner with heading, text, and button.",
    "supports": {
        "align": [
            "full",
            "wide"
        ],
        "html": false,
        "color": {
            "background": true,
            "text": true
        }
    },
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "text": {
            "type": "string",
            "default": ""
        },
        "buttonText": {
            "type": "string",
            "default": ""
        },
        "buttonUrl": {
            "type": "string",
            "default": ""
        },
        "layout": {
            "type": "string",
            "default": "horizontal"
        }
    },
    "textdomain": "fluxstack",
    "render": "file:./render.php",
    "style": "file:./style.css",
    "editorScript": "file:../../public/blocks/cta-block/editor.js"
}